---
import type { ProposalCategory } from '../lib/types';

interface Props {
  category: ProposalCategory;
}

const { category } = Astro.props;

const colors: Record<ProposalCategory, string> = {
  'Personnage': 'bg-purple-500/15 text-purple-300',
  'Lieu': 'bg-emerald-500/15 text-emerald-300',
  'Événement': 'bg-amber-500/15 text-amber-300',
  'Objet/Artefact': 'bg-blue-500/15 text-blue-300',
  'Twist': 'bg-rose-500/15 text-rose-300',
  'Lore': 'bg-cyan-500/15 text-cyan-300',
};
---

<span class:list={['text-[10px] font-semibold px-2.5 py-0.5 rounded-full tracking-wide', colors[category]]}>
  {category}
</span>
