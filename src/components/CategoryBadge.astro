---
import type { ProposalCategory } from '../lib/types';

interface Props {
  category: ProposalCategory;
}

const { category } = Astro.props;

const colors: Record<ProposalCategory, string> = {
  'Personnage': 'bg-ether-600/20 text-ether-300 border-ether-600/30',
  'Lieu': 'bg-awakened-500/20 text-awakened-300 border-awakened-500/30',
  'Événement': 'bg-fracture-500/20 text-fracture-300 border-fracture-500/30',
  'Objet/Artefact': 'bg-purple-600/20 text-purple-300 border-purple-600/30',
  'Twist': 'bg-danger-500/20 text-danger-400 border-danger-500/30',
  'Lore': 'bg-cyan-600/20 text-cyan-300 border-cyan-600/30',
};
---

<span class:list={['text-xs px-2 py-0.5 rounded-full border', colors[category]]}>
  {category}
</span>
