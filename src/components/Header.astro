---
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/lecture', label: 'Lire' },
  { href: '/participer', label: 'Participer' },
  { href: '/comment-ca-marche', label: 'Le process' },
  { href: '/timeline', label: 'Univers' },
];
---

<header class="border-b border-void-border bg-void/95 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-4xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href="/" class="text-lg font-bold text-text hover:text-cyan transition-colors tracking-tight">
      Résonance
    </a>

    <!-- Nav desktop -->
    <div class="hidden md:flex items-center gap-7">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-[13px] font-medium transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-cyan'
              : 'text-text-muted hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a
        href="/podcast"
        class:list={[
          'hidden sm:inline-flex items-center gap-1.5 text-[13px] font-semibold px-3.5 py-1.5 rounded-full border transition-all',
          currentPath.startsWith('/podcast')
            ? 'bg-cyan text-void border-cyan'
            : 'border-cyan/40 text-cyan hover:bg-cyan hover:text-void hover:shadow-[0_0_20px_rgba(0,212,170,0.15)]',
        ]}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        Podcast
      </a>
      <a
        href="/telechargement"
        class:list={[
          'hidden sm:inline-flex items-center gap-1.5 text-[13px] font-semibold px-3.5 py-1.5 rounded-full border transition-all',
          currentPath.startsWith('/telechargement')
            ? 'bg-cyan text-void border-cyan'
            : 'border-cyan/40 text-cyan hover:bg-cyan hover:text-void hover:shadow-[0_0_20px_rgba(0,212,170,0.15)]',
        ]}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Epub
      </a>

      {user ? (
        <div class="flex items-center gap-2">
          <a href="/profil" class="flex items-center text-text-muted hover:text-text transition-colors" title={user.login}>
            <img src={user.avatarUrl} alt={user.login} class="w-6 h-6 rounded-full ring-1 ring-void-border" />
          </a>
          <a href="/api/auth/logout" class="text-text-muted hover:text-text-secondary transition-colors hidden sm:inline" title="Déconnexion">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </a>
        </div>
      ) : (
        <a href="/api/auth/login" class="text-text-muted hover:text-text transition-colors" title="Se connecter">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
        </a>
      )}

      <!-- Bouton hamburger mobile -->
      <button id="menu-toggle" class="md:hidden ml-2 p-1 text-text-muted hover:text-text transition-colors" aria-label="Menu">
        <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Nav mobile -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-void-border bg-void-light">
    <div class="px-5 py-4 flex flex-col gap-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium py-1 transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-cyan'
              : 'text-text-secondary hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/podcast"
        class:list={[
          'text-sm font-semibold py-1.5 px-4 rounded-full border w-fit transition-all',
          currentPath.startsWith('/podcast')
            ? 'bg-cyan text-void border-cyan'
            : 'border-cyan/40 text-cyan hover:bg-cyan hover:text-void',
        ]}
      >
        Podcast
      </a>
      <a
        href="/telechargement"
        class:list={[
          'text-sm font-semibold py-1.5 px-4 rounded-full border w-fit transition-all',
          currentPath.startsWith('/telechargement')
            ? 'bg-cyan text-void border-cyan'
            : 'border-cyan/40 text-cyan hover:bg-cyan hover:text-void',
        ]}
      >
        Epub
      </a>
      {!user && (
        <a href="/api/auth/login" class="text-sm text-text-muted hover:text-text-secondary transition-colors pt-2 border-t border-void-border">
          Se connecter avec GitHub
        </a>
      )}
      {user && (
        <a href="/api/auth/logout" class="text-sm text-text-muted hover:text-text-secondary transition-colors pt-2 border-t border-void-border">
          Déconnexion
        </a>
      )}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden', !open);
    iconClose.classList.toggle('hidden', open);
  });
</script>
