---
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/lecture', label: 'Lire' },
  { href: '/participer', label: 'Participer' },
  { href: '/comment-ca-marche', label: 'Le process' },
  { href: '/timeline', label: 'Univers' },
  { href: '/telechargement', label: 'Epub' },
];
---

<header class="border-b border-void-border bg-void/95 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-4xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href="/" class="text-lg font-bold text-text hover:text-cyan transition-colors tracking-tight">
      Résonance
    </a>

    <!-- Nav desktop -->
    <div class="hidden md:flex items-center gap-7">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-[13px] font-medium transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-cyan'
              : 'text-text-muted hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      {user ? (
        <div class="flex items-center gap-3">
          <a href="/profil" class="flex items-center gap-2 text-[13px] text-text-secondary hover:text-text transition-colors">
            <img src={user.avatarUrl} alt={user.login} class="w-6 h-6 rounded-full ring-1 ring-void-border" />
            <span class="hidden sm:inline">{user.login}</span>
          </a>
          <a href="/api/auth/logout" class="text-xs text-text-muted hover:text-text-secondary transition-colors hidden sm:inline">
            Quitter
          </a>
        </div>
      ) : (
        <a href="/api/auth/login" class="text-[13px] font-semibold text-cyan hover:brightness-110 transition">
          Connexion
        </a>
      )}

      <!-- Bouton hamburger mobile -->
      <button id="menu-toggle" class="md:hidden ml-2 p-1 text-text-muted hover:text-text transition-colors" aria-label="Menu">
        <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Nav mobile -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-void-border bg-void-light">
    <div class="px-5 py-4 flex flex-col gap-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium py-1 transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-cyan'
              : 'text-text-secondary hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
      {user && (
        <a href="/api/auth/logout" class="text-sm text-text-muted hover:text-text-secondary transition-colors pt-2 border-t border-void-border">
          Déconnexion
        </a>
      )}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden', !open);
    iconClose.classList.toggle('hidden', open);
  });
</script>
