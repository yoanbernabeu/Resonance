---
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/lecture', label: 'Lecture' },
  { href: '/propositions', label: 'Propositions' },
  { href: '/votes', label: 'Votes' },
  { href: '/timeline', label: 'Lore' },
  { href: '/telechargement', label: 'Epub' },
];
---

<header class="border-b border-void-700 bg-void-900/80 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-display text-xl font-bold text-white hover:text-ether-400 transition-colors">
      Résonance
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-ether-400 font-medium'
              : 'text-slate-400 hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      {user ? (
        <div class="flex items-center gap-3">
          <a href="/profil" class="flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors">
            <img src={user.avatarUrl} alt={user.login} class="w-7 h-7 rounded-full" />
            <span class="hidden sm:inline">{user.login}</span>
          </a>
          <a href="/api/auth/logout" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">
            Déconnexion
          </a>
        </div>
      ) : (
        <a
          href="/api/auth/login"
          class="text-sm px-4 py-2 bg-void-700 hover:bg-void-600 text-slate-200 rounded-lg transition-colors border border-void-600"
        >
          Se connecter
        </a>
      )}
    </div>
  </nav>
</header>
