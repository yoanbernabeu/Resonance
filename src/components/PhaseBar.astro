---
import type { Phase } from '../lib/types';

interface Props {
  currentPhase: Phase | null;
  chapterTitle: string | null;
}

const { currentPhase, chapterTitle } = Astro.props;

const steps: Array<{ id: Phase; label: string }> = [
  { id: 'propositions', label: 'Propositions' },
  { id: 'votes', label: 'Votes' },
  { id: 'redaction', label: 'Écriture' },
];

function stepState(stepId: Phase): 'active' | 'done' | 'upcoming' {
  if (!currentPhase) return 'upcoming';
  const order: Phase[] = ['propositions', 'votes', 'redaction'];
  const ci = order.indexOf(currentPhase);
  const si = order.indexOf(stepId);
  if (si < ci) return 'done';
  if (si === ci) return 'active';
  return 'upcoming';
}
---

{currentPhase && (
  <div class="border-b border-void-border bg-void-light/50 backdrop-blur-sm">
    <div class="max-w-md mx-auto px-5 py-2.5 flex items-center justify-center gap-1.5">
      {steps.map((step, i) => {
        const state = stepState(step.id);
        return (
          <>
            {i > 0 && (
              <svg class="w-3 h-3 text-text-muted/20 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            )}
            {state === 'active' ? (
              <a
                href={step.id === 'redaction' ? '/lecture' : '/participer'}
                class:list={[
                  'inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1 rounded-full transition-all',
                  step.id === 'propositions' && 'bg-phase-propose/15 text-phase-propose hover:bg-phase-propose/25',
                  step.id === 'votes' && 'bg-phase-vote/15 text-phase-vote hover:bg-phase-vote/25',
                  step.id === 'redaction' && 'bg-phase-write/15 text-phase-write hover:bg-phase-write/25',
                ]}
              >
                <span class:list={[
                  'w-1.5 h-1.5 rounded-full animate-pulse',
                  step.id === 'propositions' && 'bg-phase-propose',
                  step.id === 'votes' && 'bg-phase-vote',
                  step.id === 'redaction' && 'bg-phase-write',
                ]} />
                {step.label}
              </a>
            ) : (
              <span class:list={[
                'text-xs px-2 py-1',
                state === 'done' ? 'text-text-muted' : 'text-text-muted/30',
              ]}>
                {step.label}
              </span>
            )}
          </>
        );
      })}
    </div>
  </div>
)}
