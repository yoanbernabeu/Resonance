---
---
<div
  id="podcast-player"
  class="fixed bottom-0 inset-x-0 z-40 bg-void-card/95 backdrop-blur-md border-t border-cyan/15 shadow-[0_-4px_30px_rgba(0,0,0,0.5)] hidden"
  transition:persist="podcast-player"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-5 py-3 flex items-center gap-3 sm:gap-4">
    <button
      id="pp-toggle"
      class="w-11 h-11 shrink-0 rounded-full bg-cyan text-void flex items-center justify-center hover:brightness-110 transition-all shadow-[0_0_20px_rgba(0,212,170,0.3)]"
      aria-label="Lecture/Pause"
    >
      <svg id="pp-icon-play" class="w-5 h-5 translate-x-[1px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      <svg id="pp-icon-pause" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
    </button>

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1.5">
        <span class="hidden sm:inline-block text-[10px] tracking-[0.2em] uppercase text-cyan/80 font-semibold shrink-0">Podcast</span>
        <p id="pp-title" class="text-sm text-text font-medium truncate flex-1">—</p>
      </div>
      <div class="flex items-center gap-2">
        <span id="pp-current" class="text-[11px] tabular-nums text-text-muted w-10 text-right shrink-0">0:00</span>
        <div id="pp-progress-track" class="flex-1 relative h-4 cursor-pointer group flex items-center touch-none select-none">
          <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-1 bg-void-border rounded-full"></div>
          <div id="pp-progress-bar" class="absolute top-1/2 -translate-y-1/2 left-0 h-1 bg-cyan rounded-full pointer-events-none" style="width:0%"></div>
          <div id="pp-progress-dot" class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-cyan opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="left:0%"></div>
        </div>
        <span id="pp-duration" class="text-[11px] tabular-nums text-text-muted w-10 shrink-0">0:00</span>
      </div>
    </div>

    <button
      id="pp-close"
      class="text-text-muted hover:text-text transition-colors shrink-0 p-2"
      aria-label="Fermer le lecteur"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <audio id="pp-audio" preload="none"></audio>
</div>

<script>
  const STORAGE_KEY = 'podcast-player-state';

  interface PlayerState {
    src: string;
    title: string;
    currentTime: number;
  }

  function formatTime(s: number): string {
    if (!isFinite(s) || s < 0) s = 0;
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = Math.floor(s % 60);
    const ss = String(sec).padStart(2, '0');
    if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${ss}`;
    return `${m}:${ss}`;
  }

  function setupPlayer() {
    const audio = document.getElementById('pp-audio') as HTMLAudioElement | null;
    if (!audio || (audio as any).__init) {
      bindPlayButtons();
      return;
    }
    (audio as any).__init = true;

    const root = document.getElementById('podcast-player')!;
    const toggle = document.getElementById('pp-toggle')!;
    const iconPlay = document.getElementById('pp-icon-play')!;
    const iconPause = document.getElementById('pp-icon-pause')!;
    const titleEl = document.getElementById('pp-title')!;
    const currentEl = document.getElementById('pp-current')!;
    const durationEl = document.getElementById('pp-duration')!;
    const bar = document.getElementById('pp-progress-bar') as HTMLElement;
    const dot = document.getElementById('pp-progress-dot') as HTMLElement;
    const track = document.getElementById('pp-progress-track') as HTMLElement;
    const closeBtn = document.getElementById('pp-close')!;

    const show = () => root.classList.remove('hidden');
    const hide = () => root.classList.add('hidden');

    const saveState = () => {
      if (!audio.src) return;
      const state: PlayerState = {
        src: audio.src,
        title: titleEl.textContent || '',
        currentTime: audio.currentTime,
      };
      try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
    };

    const loadState = () => {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const s = JSON.parse(raw) as PlayerState;
        if (!s.src) return;
        audio.src = s.src;
        titleEl.textContent = s.title;
        const restore = () => {
          if (s.currentTime) audio.currentTime = s.currentTime;
          audio.removeEventListener('loadedmetadata', restore);
        };
        audio.addEventListener('loadedmetadata', restore);
        show();
      } catch {}
    };

    const playUrl = (url: string, title: string) => {
      if (audio.src !== url) {
        audio.src = url;
        audio.currentTime = 0;
      }
      titleEl.textContent = title;
      show();
      audio.play().catch(() => {});
    };

    toggle.addEventListener('click', () => {
      if (!audio.src) return;
      if (audio.paused) audio.play().catch(() => {});
      else audio.pause();
    });

    audio.addEventListener('play', () => {
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
    });
    audio.addEventListener('pause', () => {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      saveState();
    });
    audio.addEventListener('timeupdate', () => {
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      bar.style.width = pct + '%';
      dot.style.left = pct + '%';
      currentEl.textContent = formatTime(audio.currentTime);
    });
    audio.addEventListener('loadedmetadata', () => {
      durationEl.textContent = formatTime(audio.duration);
    });
    audio.addEventListener('ended', () => {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      saveState();
    });

    setInterval(() => { if (!audio.paused) saveState(); }, 4000);

    let isDragging = false;
    let wasPlaying = false;
    const seekFromPointer = (clientX: number) => {
      if (!audio.duration || !isFinite(audio.duration)) return;
      const rect = track.getBoundingClientRect();
      const ratio = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
      audio.currentTime = ratio * audio.duration;
    };
    track.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      isDragging = true;
      wasPlaying = !audio.paused;
      if (wasPlaying) audio.pause();
      try { track.setPointerCapture(e.pointerId); } catch {}
      dot.style.opacity = '1';
      seekFromPointer(e.clientX);
    });
    track.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      seekFromPointer(e.clientX);
    });
    const endDrag = (e: PointerEvent) => {
      if (!isDragging) return;
      isDragging = false;
      try { track.releasePointerCapture(e.pointerId); } catch {}
      dot.style.opacity = '';
      if (wasPlaying) audio.play().catch(() => {});
      saveState();
    };
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);

    closeBtn.addEventListener('click', () => {
      audio.pause();
      audio.removeAttribute('src');
      audio.load();
      hide();
      try { sessionStorage.removeItem(STORAGE_KEY); } catch {}
      updateBodyPadding(false);
    });

    window.addEventListener('podcast:play', ((e: CustomEvent<{ url: string; title: string }>) => {
      playUrl(e.detail.url, e.detail.title);
      updateBodyPadding(true);
    }) as EventListener);

    loadState();
    if (!root.classList.contains('hidden')) updateBodyPadding(true);

    bindPlayButtons();
  }

  function updateBodyPadding(visible: boolean) {
    document.body.style.paddingBottom = visible ? '84px' : '';
  }

  function bindPlayButtons() {
    document.querySelectorAll<HTMLElement>('[data-podcast-play]').forEach((el) => {
      if ((el as any).__bound) return;
      (el as any).__bound = true;
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const url = el.dataset.podcastPlay || '';
        const title = el.dataset.podcastTitle || '';
        if (!url) return;
        window.dispatchEvent(new CustomEvent('podcast:play', { detail: { url, title } }));
      });
    });
  }

  setupPlayer();
  document.addEventListener('astro:page-load', setupPlayer);
</script>
