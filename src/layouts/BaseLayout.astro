---
import '../styles/global.css';
import Header from '../components/Header.astro';
import PhaseBar from '../components/PhaseBar.astro';
import Footer from '../components/Footer.astro';
import { getActivePhase } from '../lib/phase';

interface Props {
  title: string;
  description?: string;
  hidePhaseBar?: boolean;
}

const { title, description = 'Résonance — Une expérience d\'écriture collective assistée par IA', hidePhaseBar = false } = Astro.props;

const phaseInfo = await getActivePhase().catch(() => ({ phase: null, chapterTitle: null, issueNumber: null }));

const canonicalUrl = Astro.url.href;
const ogImage = new URL('/og.webp', Astro.url).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📖</text></svg>" />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Résonance" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Geist:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400;1,6..72,500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-void text-text">
    <Header />
    {!hidePhaseBar && <PhaseBar currentPhase={phaseInfo.phase} chapterTitle={phaseInfo.chapterTitle} />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
