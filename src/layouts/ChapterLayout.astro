---
import BaseLayout from './BaseLayout.astro';
import type { ChapterMeta } from '../lib/types';

interface Props {
  chapter: ChapterMeta;
  prevChapter: ChapterMeta | null;
  nextChapter: ChapterMeta | null;
}

const { chapter, prevChapter, nextChapter } = Astro.props;
---

<BaseLayout title={`${chapter.titre} — Résonance`} description={chapter.resume}>
  <article class="max-w-2xl mx-auto px-5 py-16 md:py-24">
    <header class="mb-12">
      <p class="text-xs font-semibold text-cyan uppercase tracking-wider mb-2">
        {chapter.numero === 0 ? 'Prologue' : `Chapitre ${chapter.numero}`}
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-text leading-snug tracking-tight">
        {chapter.titre}
      </h1>
    </header>

    <div class="prose">
      <slot />
    </div>

    <nav class="mt-16 pt-6 border-t border-void-border flex justify-between items-center">
      {prevChapter ? (
        <a href={`/lecture/${prevChapter.slug}`} class="text-sm text-text-secondary hover:text-cyan transition-colors">
          ← {prevChapter.titre}
        </a>
      ) : <span></span>}
      <a href="/lecture" class="text-xs text-text-muted hover:text-text-secondary transition-colors">
        Sommaire
      </a>
      {nextChapter ? (
        <a href={`/lecture/${nextChapter.slug}`} class="text-sm text-text-secondary hover:text-cyan transition-colors">
          {nextChapter.titre} →
        </a>
      ) : <span></span>}
    </nav>
  </article>
</BaseLayout>
