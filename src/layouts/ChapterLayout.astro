---
import BaseLayout from './BaseLayout.astro';
import type { ChapterMeta } from '../lib/types';

interface Props {
  chapter: ChapterMeta;
  prevChapter: ChapterMeta | null;
  nextChapter: ChapterMeta | null;
}

const { chapter, prevChapter, nextChapter } = Astro.props;
---

<BaseLayout title={`${chapter.titre} — Résonance`} description={chapter.resume}>
  <article class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <!-- En-tête -->
    <header class="text-center mb-12">
      <p class="text-ether-400 text-sm font-medium tracking-widest uppercase mb-4">
        {chapter.numero === 0 ? 'Prologue' : `Chapitre ${chapter.numero}`}
      </p>
      <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
        {chapter.titre}
      </h1>
      <p class="text-sm text-slate-500">{chapter.datePublication}</p>
    </header>

    <!-- Contenu -->
    <div class="prose mx-auto">
      <slot />
    </div>

    <!-- Navigation -->
    <nav class="mt-16 pt-8 border-t border-void-700 flex justify-between items-center">
      {prevChapter ? (
        <a
          href={`/lecture/${prevChapter.slug}`}
          class="text-sm text-slate-400 hover:text-ether-400 transition-colors"
        >
          &larr; {prevChapter.titre}
        </a>
      ) : (
        <span></span>
      )}
      <a href="/lecture" class="text-sm text-slate-500 hover:text-white transition-colors">
        Table des matières
      </a>
      {nextChapter ? (
        <a
          href={`/lecture/${nextChapter.slug}`}
          class="text-sm text-slate-400 hover:text-ether-400 transition-colors"
        >
          {nextChapter.titre} &rarr;
        </a>
      ) : (
        <span></span>
      )}
    </nav>
  </article>
</BaseLayout>
