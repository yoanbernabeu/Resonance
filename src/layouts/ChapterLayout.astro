---
import BaseLayout from './BaseLayout.astro';
import type { ChapterMeta } from '../lib/types';

interface Props {
  chapter: ChapterMeta;
  prevChapter: ChapterMeta | null;
  nextChapter: ChapterMeta | null;
}

const { chapter, prevChapter, nextChapter } = Astro.props;
---

<BaseLayout title={`${chapter.titre} — Résonance`} description={chapter.resume}>
  <article class="max-w-2xl mx-auto px-5 py-16 md:py-24">
    <header class="text-center mb-14">
      <p class="text-xs tracking-[0.3em] uppercase text-cyan mb-4">
        {chapter.numero === 0 ? 'Prologue' : `Chapitre ${chapter.numero}`}
      </p>
      <h1 class="font-[--font-display] text-3xl md:text-4xl text-text leading-snug">
        {chapter.titre}
      </h1>
      <div class="w-8 h-px bg-cyan/30 mx-auto mt-6"></div>
    </header>

    <div class="prose mx-auto">
      <slot />
    </div>

    <nav class="mt-16 pt-8 border-t border-void-border flex justify-between items-center gap-4">
      {prevChapter ? (
        <a href={`/lecture/${prevChapter.slug}`} class="group flex items-center gap-2 text-sm text-text-secondary hover:text-cyan transition-colors min-w-0">
          <svg class="w-4 h-4 shrink-0 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          <span class="truncate">{prevChapter.titre}</span>
        </a>
      ) : <span></span>}
      <a href="/lecture" class="text-xs text-text-muted hover:text-text-secondary transition-colors shrink-0">
        Sommaire
      </a>
      {nextChapter ? (
        <a href={`/lecture/${nextChapter.slug}`} class="group flex items-center gap-2 text-sm text-text-secondary hover:text-cyan transition-colors min-w-0 text-right">
          <span class="truncate">{nextChapter.titre}</span>
          <svg class="w-4 h-4 shrink-0 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ) : <span></span>}
    </nav>
  </article>
</BaseLayout>
