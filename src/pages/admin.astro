---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllChapterIssues } from '../lib/github';

const user = Astro.locals.user;
const repoOwner = import.meta.env.GITHUB_REPO_OWNER;
if (!user || user.login !== repoOwner) return new Response('Non autorisé', { status: 403 });

const issues = await getAllChapterIssues().catch(() => []);
---

<BaseLayout title="Admin — Résonance">
  <div class="max-w-2xl mx-auto px-5 py-16 md:py-24">
    <h1 class="text-3xl font-bold text-text mb-8 tracking-tight">Administration</h1>

    <div class="bg-void-card border border-void-border rounded-xl p-5 mb-10">
      <p class="font-semibold text-text mb-3">Nouveau chapitre</p>
      <button id="btn-new" class="text-sm font-semibold px-4 py-2 bg-cyan text-void rounded-lg hover:brightness-110 transition">
        Créer l'issue
      </button>
      <p id="msg" class="text-sm mt-2 hidden"></p>
    </div>

    {issues.length > 0 && (
      <div>
        <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-4">Chapitres</p>
        <div class="space-y-1">
          {issues.map(issue => (
            <div class="flex items-center justify-between py-3 border-b border-void-border">
              <div class="flex items-center gap-3">
                <span class="text-sm text-text">{issue.title}</span>
                <span class:list={['text-xs font-medium px-2 py-0.5 rounded',
                  issue.phase === 'propositions' && 'bg-phase-propose/15 text-phase-propose',
                  issue.phase === 'votes' && 'bg-phase-vote/15 text-phase-vote',
                  issue.phase === 'redaction' && 'bg-phase-write/15 text-phase-write',
                  !issue.phase && 'bg-text-muted/10 text-text-muted',
                ]}>
                  {issue.phase || 'terminé'}
                </span>
              </div>
              {issue.phase === 'propositions' && (
                <button class="phase-btn text-xs font-semibold text-phase-vote hover:brightness-110 transition" data-issue-number={issue.number} data-new-phase="votes">→ Votes</button>
              )}
              {issue.phase === 'votes' && (
                <button class="phase-btn text-xs font-semibold text-phase-write hover:brightness-110 transition" data-issue-number={issue.number} data-new-phase="redaction">→ Rédaction</button>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <script>
    document.getElementById('btn-new')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement; const msg = document.getElementById('msg')!; btn.disabled = true;
      try { const res = await fetch('/api/admin/phase', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'create' }) });
        if (res.ok) { msg.textContent = 'Créé.'; msg.className = 'text-sm mt-2 text-cyan'; setTimeout(() => location.reload(), 800); }
        else { const d = await res.json(); msg.textContent = d.error; msg.className = 'text-sm mt-2 text-red'; btn.disabled = false; }
      } catch { msg.textContent = 'Erreur.'; msg.className = 'text-sm mt-2 text-red'; btn.disabled = false; }
    });
    document.querySelectorAll('.phase-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => { const t = e.currentTarget as HTMLButtonElement; t.disabled = true;
        try { const res = await fetch('/api/admin/phase', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'transition', issueNumber: Number(t.dataset.issueNumber), newPhase: t.dataset.newPhase }) });
          if (res.ok) location.reload(); else t.disabled = false; } catch { t.disabled = false; }
      });
    });
  </script>
</BaseLayout>
