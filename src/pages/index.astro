---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllChapters } from '../lib/chapters';
import { getActivePhase } from '../lib/phase';

const chapters = await getAllChapters();
const phaseInfo = await getActivePhase().catch(() => ({ phase: null, chapterTitle: null, issueNumber: null }));
---

<BaseLayout title="Résonance — Écriture collective assistée par IA">
  <!-- Fond atmosphérique -->
  <div class="absolute top-0 left-0 right-0 h-[700px] bg-[radial-gradient(ellipse_at_50%_0%,_rgba(0,212,170,0.05)_0%,_transparent_70%)] pointer-events-none"></div>

  <div class="relative max-w-2xl mx-auto px-5">
    <!-- Hero -->
    <section class="pt-12 md:pt-24">
      <p class="text-sm text-cyan font-medium mb-4 fade-up">Un roman de SF écrit par la communauté</p>

      <h1 class="text-4xl md:text-6xl font-bold text-text leading-[1.1] mb-5 tracking-tight fade-up fade-up-1">
        Résonance
      </h1>

      <p class="text-text-secondary leading-relaxed mb-6 fade-up fade-up-2">
        L'Hégémonie Solaire s'est effondrée. Dans la Lisière, les vestiges des <strong class="text-text">Bâtisseurs</strong> — une civilisation alien disparue — semblent encore <em class="text-cyan not-italic">résonner</em>. Les <strong class="text-text">Éveillé·e·s</strong>, des humains aux capacités extraordinaires, vivent cachés. Quelque chose dort dans les fondations de la galaxie.
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row gap-3 fade-up fade-up-3">
        {phaseInfo.phase === 'propositions' ? (
          <a href="/participer" class="text-sm font-semibold px-5 py-2.5 bg-cyan text-void rounded-lg hover:brightness-110 transition text-center">
            Proposer une idée →
          </a>
        ) : phaseInfo.phase === 'votes' ? (
          <a href="/participer" class="text-sm font-semibold px-5 py-2.5 bg-cyan text-void rounded-lg hover:brightness-110 transition text-center">
            Voter maintenant →
          </a>
        ) : (
          <a href="/lecture" class="text-sm font-semibold px-5 py-2.5 bg-cyan text-void rounded-lg hover:brightness-110 transition text-center">
            Commencer la lecture →
          </a>
        )}
        <a href="/comment-ca-marche" class="text-sm font-medium px-5 py-2.5 text-text-muted hover:text-text border border-void-border hover:border-void-border-hover rounded-lg transition-colors text-center">
          Comment participer ?
        </a>
      </div>
    </section>

    <!-- Chapitres -->
    {chapters.length > 0 && (
      <section class="pt-16 pb-12 mt-4 border-t border-void-border">
        <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-6">Chapitres publiés</p>
        <div>
          {chapters.map((chapter) => (
            <a
              href={`/lecture/${chapter.slug}`}
              class="flex items-baseline gap-4 py-3 border-b border-void-border hover:bg-void-card -mx-3 px-3 rounded-lg transition-colors group"
            >
              <span class="text-xs text-text-muted w-6 text-right tabular-nums shrink-0">
                {chapter.numero === 0 ? '—' : chapter.numero}
              </span>
              <div>
                <span class="text-text group-hover:text-cyan transition-colors font-medium">
                  {chapter.titre}
                </span>
                <p class="text-sm text-text-secondary mt-0.5">{chapter.resume}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}


  </div>
</BaseLayout>
