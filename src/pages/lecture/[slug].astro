---
export const prerender = true;

import ChapterLayout from '../../layouts/ChapterLayout.astro';
import { getAllChapters, getChapter } from '../../lib/chapters';
import { marked } from 'marked';

export async function getStaticPaths() {
  const chapters = await getAllChapters();
  return chapters.map((ch, i) => ({
    params: { slug: ch.slug },
    props: {
      prev: i > 0 ? chapters[i - 1] : null,
      next: i < chapters.length - 1 ? chapters[i + 1] : null,
    },
  }));
}

const { slug } = Astro.params;
const { prev: prevChapter, next: nextChapter } = Astro.props as {
  prev: Awaited<ReturnType<typeof getAllChapters>>[number] | null;
  next: Awaited<ReturnType<typeof getAllChapters>>[number] | null;
};

const chapter = await getChapter(slug!);
if (!chapter) {
  return Astro.redirect('/lecture');
}

const htmlContent = await marked.parse(chapter.content);
---

<ChapterLayout chapter={chapter.meta} prevChapter={prevChapter} nextChapter={nextChapter}>
  <Fragment set:html={htmlContent} />
</ChapterLayout>
