---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllChapters } from '../../lib/chapters';

const chapters = await getAllChapters();
---

<BaseLayout title="Lecture — Résonance" description="Tous les chapitres publiés de Résonance">
  <div class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <header class="text-center mb-12">
      <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
        Table des matières
      </h1>
      <p class="text-slate-400">
        {chapters.length} {chapters.length > 1 ? 'chapitres publiés' : 'chapitre publié'}
      </p>
    </header>

    <div class="space-y-4">
      {chapters.map((chapter) => (
        <a
          href={`/lecture/${chapter.slug}`}
          class="block bg-void-800/30 border border-void-700 hover:border-ether-600/50 rounded-xl p-6 transition-all group"
        >
          <div class="flex items-baseline gap-4 mb-2">
            <span class="text-ether-500/50 font-display text-sm font-semibold shrink-0">
              {chapter.numero === 0 ? 'Prologue' : `Ch. ${chapter.numero}`}
            </span>
            <h2 class="font-display text-lg font-semibold text-white group-hover:text-ether-400 transition-colors">
              {chapter.titre}
            </h2>
          </div>
          <p class="text-sm text-slate-400 ml-0 md:ml-[4.5rem]">{chapter.resume}</p>
          <p class="text-xs text-slate-600 mt-2 ml-0 md:ml-[4.5rem]">{chapter.datePublication}</p>
        </a>
      ))}
    </div>

    {chapters.length === 0 && (
      <p class="text-center text-slate-500 py-12">Aucun chapitre publié pour le moment.</p>
    )}
  </div>
</BaseLayout>
