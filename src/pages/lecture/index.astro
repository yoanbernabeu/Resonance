---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllChapters } from '../../lib/chapters';
const chapters = await getAllChapters();
---

<BaseLayout title="Lecture — Résonance">
  <div class="max-w-2xl mx-auto px-5 py-16 md:py-24">
    <h1 class="text-3xl font-bold text-text mb-8 tracking-tight">Table des matières</h1>
    <div>
      {chapters.map(ch => (
        <a href={`/lecture/${ch.slug}`} class="flex items-baseline gap-4 py-3 border-b border-void-border hover:bg-void-card -mx-3 px-3 rounded-lg transition-colors group">
          <span class="text-xs text-text-muted w-6 text-right tabular-nums shrink-0">{ch.numero === 0 ? '—' : ch.numero}</span>
          <div>
            <span class="text-text group-hover:text-cyan transition-colors font-medium">{ch.titre}</span>
            <p class="text-sm text-text-secondary mt-0.5">{ch.resume}</p>
          </div>
        </a>
      ))}
    </div>
    {chapters.length === 0 && <p class="text-text-secondary py-12">Aucun chapitre publié.</p>}
  </div>
</BaseLayout>
