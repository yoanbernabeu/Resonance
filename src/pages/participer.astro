---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { getActiveChapterIssue, getProposals, getUserProposalCount } from '../lib/github';
import { getActivePhase } from '../lib/phase';
import { PROPOSAL_CATEGORIES } from '../lib/types';

const user = Astro.locals.user;
const phaseInfo = await getActivePhase().catch(() => ({ phase: null, chapterTitle: null, issueNumber: null }));

let proposals: Awaited<ReturnType<typeof getProposals>> = [];
let userCount = 0;

if (phaseInfo.issueNumber) {
  proposals = (await getProposals(phaseInfo.issueNumber, user?.login).catch(() => [])).filter(p => !p.isMinimized);
  if (user && phaseInfo.phase === 'propositions') {
    userCount = await getUserProposalCount(phaseInfo.issueNumber, user.login).catch(() => 0);
  }
}

const grouped = PROPOSAL_CATEGORIES
  .map(cat => ({ category: cat, items: proposals.filter(p => p.category === cat).sort((a, b) => b.score - a.score) }))
  .filter(g => g.items.length > 0);
---

<BaseLayout title="Participer — Résonance">
  <div class="max-w-2xl mx-auto px-5 py-16 md:py-24">

    {/* Pas de phase active */}
    {!phaseInfo.phase && (
      <div class="text-center py-20">
        <p class="text-xs tracking-[0.3em] uppercase text-text-muted mb-4">En attente</p>
        <h1 class="font-[--font-display] text-3xl sm:text-4xl text-text mb-4">Aucun chapitre en cours</h1>
        <p class="text-text-secondary max-w-md mx-auto mb-8">Le prochain cycle n'a pas encore commencé. Revenez bientôt !</p>
        <a href="/lecture" class="group inline-flex items-center gap-2 text-sm font-semibold px-6 py-2.5 rounded-full border border-void-border hover:border-cyan/30 text-text-muted hover:text-cyan transition-all">
          Lire les chapitres publiés
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    )}

    {/* Phase propositions */}
    {phaseInfo.phase === 'propositions' && (
      <>
        <div class="text-center mb-12">
          <p class="text-xs tracking-[0.3em] uppercase text-phase-propose mb-4">Propositions ouvertes</p>
          <h1 class="font-[--font-display] text-3xl sm:text-4xl text-text mb-3">{phaseInfo.chapterTitle}</h1>
          <p class="text-text-secondary max-w-md mx-auto">
            Soumettez vos idées : personnages, lieux, événements, twists. 3 propositions max par personne.
          </p>
        </div>

        <div class="bg-void-card/30 border border-cyan/10 rounded-xl px-5 py-4 mb-10 flex items-start gap-4">
          <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <p class="text-sm text-text-secondary">
            Avant de proposer, prenez le temps de <a href="/lecture" class="text-cyan font-semibold hover:underline">lire l'intégralité du roman</a> pour que vos idées s'inscrivent dans la continuité de l'histoire.
          </p>
        </div>

        {!user ? (
          <div class="bg-void-card/40 border border-void-border rounded-2xl p-10 text-center">
            <p class="text-text-secondary mb-5">Connectez-vous pour soumettre vos idées.</p>
            <a href="/api/auth/login?redirect_to=/participer" data-astro-reload class="group inline-flex items-center gap-2 text-sm font-semibold px-6 py-2.5 bg-cyan text-void rounded-full hover:brightness-110 transition-all hover:shadow-[0_0_30px_rgba(0,212,170,0.2)]">
              Se connecter avec GitHub
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        ) : (
          <>
            <div class="bg-void-card/40 border border-void-border rounded-2xl p-6 mb-10">
              <div class="flex items-center justify-between mb-5">
                <p class="font-semibold text-text">Nouvelle proposition</p>
                <span class:list={['text-xs font-semibold px-2.5 py-1 rounded-full', userCount >= 3 ? 'bg-red/10 text-red' : 'bg-void-card text-text-muted']}>
                  {userCount}/3
                </span>
              </div>

              {userCount >= 3 ? (
                <p class="text-sm text-text-secondary">Limite de 3 propositions atteinte.</p>
              ) : (
                <form id="proposal-form" class="space-y-3">
                  <input type="hidden" name="issueNumber" value={phaseInfo.issueNumber} />
                  <select name="category" required class="w-full bg-void border border-void-border rounded-xl px-4 py-2.5 text-sm text-text focus:border-cyan/40 focus:outline-none transition-colors">
                    <option value="">Catégorie…</option>
                    {PROPOSAL_CATEGORIES.map(cat => <option value={cat}>{cat}</option>)}
                  </select>
                  <textarea name="description" required rows={3} maxlength={1000} placeholder="Votre idée…" class="w-full bg-void border border-void-border rounded-xl px-4 py-2.5 text-sm text-text focus:border-cyan/40 focus:outline-none resize-y placeholder:text-text-muted transition-colors"></textarea>
                  <button type="submit" class="text-sm font-semibold px-5 py-2 bg-cyan text-void rounded-full hover:brightness-110 transition-all hover:shadow-[0_0_20px_rgba(0,212,170,0.15)] disabled:opacity-30">
                    Soumettre
                  </button>
                  <p id="form-message" class="text-sm hidden"></p>
                </form>
              )}
            </div>

            {proposals.length > 0 && (
              <div>
                <p class="text-xs tracking-[0.2em] uppercase text-text-muted mb-5">{proposals.length} proposition{proposals.length > 1 ? 's' : ''} soumise{proposals.length > 1 ? 's' : ''}</p>
                <div class="space-y-2">
                  {proposals.map(p => (
                    <div class="bg-void-card/30 border border-void-border rounded-xl px-4 py-3 hover:border-void-border-hover transition-colors">
                      <div class="flex items-center gap-2 mb-1.5">
                        <img src={p.avatarUrl} alt={p.author} class="w-5 h-5 rounded-full" />
                        <span class="text-xs text-text-muted">{p.author}</span>
                        <CategoryBadge category={p.category} />
                      </div>
                      <p class="text-sm text-text-secondary leading-relaxed">{p.description}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </>
        )}
      </>
    )}

    {/* Phase votes */}
    {phaseInfo.phase === 'votes' && (
      <>
        <input type="hidden" name="issueNumber" value={phaseInfo.issueNumber} />
        <div class="text-center mb-12">
          <p class="text-xs tracking-[0.3em] uppercase text-phase-vote mb-4">Votes ouverts</p>
          <h1 class="font-[--font-display] text-3xl sm:text-4xl text-text mb-3">{phaseInfo.chapterTitle}</h1>
          <p class="text-text-secondary max-w-md mx-auto">
            Votez pour vos propositions préférées. Les mieux notées guideront l'écriture du chapitre.
          </p>
        </div>

        <div class="bg-void-card/30 border border-cyan/10 rounded-xl px-5 py-4 mb-10 flex items-start gap-4">
          <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <p class="text-sm text-text-secondary">
            Avant de voter, assurez-vous d'avoir <a href="/lecture" class="text-cyan font-semibold hover:underline">lu tous les chapitres</a> pour juger au mieux de la cohérence des propositions.
          </p>
        </div>

        {!user ? (
          <div class="bg-void-card/40 border border-void-border rounded-2xl p-10 text-center">
            <p class="text-text-secondary mb-5">Connectez-vous pour voter.</p>
            <a href="/api/auth/login?redirect_to=/participer" data-astro-reload class="group inline-flex items-center gap-2 text-sm font-semibold px-6 py-2.5 bg-cyan text-void rounded-full hover:brightness-110 transition-all hover:shadow-[0_0_30px_rgba(0,212,170,0.2)]">
              Se connecter avec GitHub
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        ) : grouped.length === 0 ? (
          <p class="text-text-secondary text-center py-12">Aucune proposition à voter.</p>
        ) : (
          <div class="space-y-10">
            {grouped.map(group => (
              <section>
                <div class="flex items-center gap-2.5 mb-4">
                  <CategoryBadge category={group.category} />
                  <span class="text-xs text-text-muted">{group.items.length}</span>
                </div>
                <div class="space-y-2">
                  {group.items.map(p => (
                    <div class="flex gap-3 bg-void-card/30 border border-void-border rounded-xl px-4 py-3 hover:border-void-border-hover transition-colors" data-proposal-id={p.id}>
                      <div class="flex flex-col items-center gap-0 shrink-0 w-8 pt-0.5">
                        <button class:list={['vote-btn text-sm leading-none py-0.5 transition-colors', p.userVote === '+1' ? 'text-cyan' : 'text-text-muted hover:text-cyan']} data-comment-id={p.id} data-vote="+1">▲</button>
                        <span class="text-xs font-semibold text-text vote-score py-0.5">{p.score}</span>
                        <button class:list={['vote-btn text-sm leading-none py-0.5 transition-colors', p.userVote === '-1' ? 'text-red' : 'text-text-muted hover:text-red']} data-comment-id={p.id} data-vote="-1">▼</button>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          <img src={p.avatarUrl} alt={p.author} class="w-4 h-4 rounded-full" />
                          <span class="text-xs text-text-muted">{p.author}</span>
                        </div>
                        <p class="text-sm text-text-secondary leading-relaxed">{p.description}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>
        )}
      </>
    )}

    {/* Phase rédaction */}
    {phaseInfo.phase === 'redaction' && (
      <div class="text-center py-20">
        <div class="inline-flex items-center gap-2 bg-phase-write/10 border border-phase-write/20 rounded-full px-4 py-1.5 mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-phase-write animate-pulse"></span>
          <span class="text-xs font-semibold text-phase-write">Rédaction en cours</span>
        </div>
        <h1 class="font-[--font-display] text-3xl sm:text-4xl text-text mb-4">Le chapitre est en cours d'écriture</h1>
        <p class="text-text-secondary max-w-md mx-auto mb-8">
          Les votes sont terminés. Le prochain chapitre est en cours de rédaction à partir de vos propositions.
        </p>
        <a href="/lecture" class="group inline-flex items-center gap-2 text-sm font-semibold px-6 py-2.5 rounded-full border border-void-border hover:border-cyan/30 text-text-muted hover:text-cyan transition-all">
          Lire les chapitres publiés
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    )}
  </div>

  <script>
    function initParticiper() {
      const form = document.getElementById('proposal-form') as HTMLFormElement | null;
      const message = document.getElementById('form-message') as HTMLElement | null;
      if (form && !(form as any).__bound) {
        (form as any).__bound = true;
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const fd = new FormData(form);
          const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
          btn.disabled = true;
          try {
            const res = await fetch('/api/proposals/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ issueNumber: Number(fd.get('issueNumber')), category: fd.get('category'), description: fd.get('description') }) });
            if (res.ok) window.location.reload();
            else { const d = await res.json(); if (message) { message.textContent = d.error || 'Erreur.'; message.className = 'text-sm text-red'; } btn.disabled = false; }
          } catch { if (message) { message.textContent = 'Erreur.'; message.className = 'text-sm text-red'; } btn.disabled = false; }
        });
      }

      document.querySelectorAll('.vote-btn').forEach(btn => {
        if ((btn as any).__bound) return;
        (btn as any).__bound = true;
        btn.addEventListener('click', async (e) => {
          const t = e.currentTarget as HTMLButtonElement; t.disabled = true;
          try {
            const issueInput = document.querySelector('input[name="issueNumber"]') as HTMLInputElement;
            const res = await fetch(t.dataset.vote === '+1' ? '/api/votes/upvote' : '/api/votes/downvote', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ commentId: Number(t.dataset.commentId), issueNumber: Number(issueInput?.value) }) });
            if (res.ok) window.location.reload();
          } catch {} finally { t.disabled = false; }
        });
      });
    }
    initParticiper();
    document.addEventListener('astro:page-load', initParticiper);
  </script>
</BaseLayout>
