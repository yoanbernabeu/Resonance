---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { getAllChapterIssues, getProposals } from '../lib/github';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/api/auth/login?redirect_to=/profil');

const issues = await getAllChapterIssues().catch(() => []);
const userProposals: Array<{ chapterTitle: string; proposals: Awaited<ReturnType<typeof getProposals>> }> = [];
for (const issue of issues) {
  const proposals = await getProposals(issue.number, user.login).catch(() => []);
  const mine = proposals.filter(p => p.author === user.login && !p.isMinimized);
  if (mine.length > 0) userProposals.push({ chapterTitle: issue.title, proposals: mine });
}
---

<BaseLayout title="Profil — Résonance">
  <div class="max-w-2xl mx-auto px-5 py-16 md:py-24">
    <div class="flex items-center gap-4 mb-10">
      <img src={user.avatarUrl} alt={user.login} class="w-12 h-12 rounded-full ring-1 ring-void-border" />
      <div>
        <h1 class="text-xl font-bold text-text">{user.login}</h1>
        <p class="text-xs text-text-muted">Contributeur·ice</p>
      </div>
    </div>

    <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-4">Mes propositions</p>

    {userProposals.length === 0 ? (
      <p class="text-text-secondary">Aucune proposition soumise.</p>
    ) : (
      <div class="space-y-8">
        {userProposals.map(({ chapterTitle, proposals }) => (
          <div>
            <p class="text-xs text-text-muted mb-3">{chapterTitle}</p>
            {proposals.map(p => (
              <div class="py-3 border-b border-void-border">
                <div class="flex items-center gap-2 mb-1">
                  <CategoryBadge category={p.category} />
                  <span class="text-xs text-text-muted">score {p.score}</span>
                </div>
                <p class="text-sm text-text-secondary">{p.description}</p>
              </div>
            ))}
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
