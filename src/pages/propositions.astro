---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { getActiveChapterIssue, getProposals, getUserProposalCount } from '../lib/github';
import { PROPOSAL_CATEGORIES } from '../lib/types';

const user = Astro.locals.user;
const activeIssue = await getActiveChapterIssue('propositions').catch(() => null);

let proposals: Awaited<ReturnType<typeof getProposals>> = [];
let userCount = 0;

if (activeIssue) {
  proposals = (await getProposals(activeIssue.number, user?.login).catch(() => [])).filter(p => !p.isMinimized);
  if (user) {
    userCount = await getUserProposalCount(activeIssue.number, user.login).catch(() => 0);
  }
}
---

<BaseLayout title="Propositions — Résonance">
  <div class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <header class="text-center mb-12">
      <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
        Propositions
      </h1>
      <p class="text-slate-400">
        Soumettez vos idées pour le prochain chapitre
      </p>
    </header>

    {!activeIssue ? (
      <div class="text-center py-16">
        <p class="text-slate-500 text-lg">Aucune phase de propositions n'est ouverte pour le moment.</p>
        <p class="text-slate-600 text-sm mt-2">Revenez bientôt !</p>
      </div>
    ) : !user ? (
      <div class="text-center py-16">
        <p class="text-slate-400 mb-4">Connectez-vous avec GitHub pour soumettre vos idées.</p>
        <a
          href={`/api/auth/login?redirect_to=/propositions`}
          class="inline-block px-6 py-3 bg-void-700 hover:bg-void-600 text-slate-200 rounded-lg transition-colors border border-void-600"
        >
          Se connecter avec GitHub
        </a>
      </div>
    ) : (
      <>
        {/* Formulaire */}
        <div class="bg-void-800/50 border border-void-700 rounded-xl p-6 mb-10">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-display text-lg font-semibold text-white">Nouvelle proposition</h2>
            <span class:list={[
              'text-sm',
              userCount >= 3 ? 'text-danger-400' : 'text-slate-500',
            ]}>
              {userCount}/3 propositions
            </span>
          </div>

          {userCount >= 3 ? (
            <p class="text-slate-400 text-sm">
              Vous avez atteint la limite de 3 propositions pour ce chapitre.
            </p>
          ) : (
            <form id="proposal-form" class="space-y-4">
              <input type="hidden" name="issueNumber" value={activeIssue.number} />

              <div>
                <label for="category" class="block text-sm text-slate-400 mb-1">Catégorie</label>
                <select
                  id="category"
                  name="category"
                  required
                  class="w-full bg-void-900 border border-void-600 rounded-lg px-3 py-2 text-slate-200 text-sm focus:border-ether-500 focus:outline-none"
                >
                  <option value="">Choisir une catégorie…</option>
                  {PROPOSAL_CATEGORIES.map(cat => (
                    <option value={cat}>{cat}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="description" class="block text-sm text-slate-400 mb-1">Votre idée</label>
                <textarea
                  id="description"
                  name="description"
                  required
                  rows={4}
                  maxlength={1000}
                  placeholder="Décrivez votre proposition…"
                  class="w-full bg-void-900 border border-void-600 rounded-lg px-3 py-2 text-slate-200 text-sm focus:border-ether-500 focus:outline-none resize-y"
                ></textarea>
              </div>

              <button
                type="submit"
                class="px-5 py-2 bg-ether-600 hover:bg-ether-500 text-white text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Soumettre
              </button>

              <p id="form-message" class="text-sm hidden"></p>
            </form>
          )}
        </div>

        {/* Liste des propositions */}
        {proposals.length > 0 && (
          <div>
            <h2 class="font-display text-xl font-semibold text-white mb-6">
              Propositions ({proposals.length})
            </h2>
            <div class="space-y-3">
              {proposals.map(proposal => (
                <div class="bg-void-800/30 border border-void-700 rounded-xl p-4">
                  <div class="flex items-center gap-3 mb-2">
                    <img src={proposal.avatarUrl} alt={proposal.author} class="w-6 h-6 rounded-full" />
                    <span class="text-sm text-slate-400">{proposal.author}</span>
                    <CategoryBadge category={proposal.category} />
                  </div>
                  <p class="text-slate-200 text-sm">{proposal.description}</p>
                </div>
              ))}
            </div>
          </div>
        )}
      </>
    )}
  </div>

  <script>
    const form = document.getElementById('proposal-form') as HTMLFormElement | null;
    const message = document.getElementById('form-message') as HTMLElement | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      button.disabled = true;

      try {
        const res = await fetch('/api/proposals/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            issueNumber: Number(formData.get('issueNumber')),
            category: formData.get('category'),
            description: formData.get('description'),
          }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          if (message) {
            message.textContent = data.error || 'Une erreur est survenue.';
            message.className = 'text-sm text-danger-400';
          }
          button.disabled = false;
        }
      } catch {
        if (message) {
          message.textContent = 'Erreur de connexion.';
          message.className = 'text-sm text-danger-400';
        }
        button.disabled = false;
      }
    });
  </script>
</BaseLayout>
