---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getServerOctokit } from '../lib/github';

const OWNER = import.meta.env.GITHUB_REPO_OWNER;
const REPO = import.meta.env.GITHUB_REPO_NAME;

interface Release { tag: string; title: string; date: string; epubUrl: string | null; epubSize: string | null; }
let releases: Release[] = [];
try {
  const octokit = getServerOctokit();
  const { data } = await octokit.repos.listReleases({ owner: OWNER, repo: REPO, per_page: 20 });
  releases = data.map(r => {
    const epub = r.assets.find(a => a.name.endsWith('.epub'));
    return { tag: r.tag_name, title: r.name || r.tag_name, date: new Date(r.published_at || r.created_at).toLocaleDateString('fr-FR'), epubUrl: epub?.browser_download_url || null, epubSize: epub ? `${(epub.size / (1024 * 1024)).toFixed(1)} Mo` : null };
  });
} catch {}
---

<BaseLayout title="Epub — Résonance">
  <div class="max-w-2xl mx-auto px-5 py-16 md:py-24">
    <h1 class="text-3xl font-bold text-text mb-2 tracking-tight">Téléchargement</h1>
    <p class="text-text-secondary mb-8">L'epub s'enrichit à chaque nouveau chapitre.</p>

    {releases.length === 0 ? (
      <div class="bg-void-card border border-void-border rounded-xl p-8 text-center">
        <p class="text-text-secondary">Aucune version disponible.</p>
        <p class="text-sm text-text-muted mt-1">Le premier epub sera généré après le premier chapitre.</p>
      </div>
    ) : (
      <div class="space-y-2">
        {releases.map((r, i) => (
          <div class="flex items-center justify-between py-3 border-b border-void-border">
            <div>
              <p class:list={['text-sm', i === 0 ? 'font-semibold text-text' : 'text-text-secondary']}>
                {r.title}
                {i === 0 && <span class="ml-2 text-xs text-cyan">dernière</span>}
              </p>
              <p class="text-xs text-text-muted">{r.date} · {r.tag}</p>
            </div>
            {r.epubUrl ? (
              <a href={r.epubUrl} class="text-sm font-semibold text-cyan hover:brightness-110 transition">
                .epub {r.epubSize && `(${r.epubSize})`}
              </a>
            ) : (
              <span class="text-xs text-text-muted">en cours…</span>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
