---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLore } from '../lib/lore';
const lore = await getLore();
---

<BaseLayout title="Univers — Résonance">
  <div class="max-w-2xl mx-auto px-5 py-16 md:py-24">
    <h1 class="text-3xl font-bold text-text mb-2 tracking-tight">L'Univers</h1>
    <p class="text-text-secondary mb-12">Encyclopédie vivante, enrichie à chaque chapitre.</p>

    <section class="mb-14">
      <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-5">Chronologie</p>
      <div class="space-y-5 border-l-2 border-cyan/20 pl-5">
        {lore.evenementsCles.map(e => (
          <div>
            <p class="text-sm font-semibold text-text">{e.nom}</p>
            <p class="text-sm text-text-secondary mt-0.5">{e.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-14">
      <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-5">Factions</p>
      <div class="grid md:grid-cols-2 gap-3">
        {lore.factions.map(f => (
          <div class="bg-void-card border border-void-border rounded-xl p-4">
            <div class="flex items-center justify-between mb-1">
              <p class="text-sm font-semibold text-text">{f.nom}</p>
              <span class="text-xs text-text-muted">{f.statut}</span>
            </div>
            <p class="text-sm text-text-secondary">{f.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-14">
      <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-5">Lieux</p>
      <div class="grid md:grid-cols-2 gap-3">
        {lore.lieux.map(l => (
          <div class="bg-void-card border border-void-border rounded-xl p-4">
            <p class="text-sm font-semibold text-text">{l.nom} <span class="text-text-muted font-normal">({l.type})</span></p>
            <p class="text-sm text-text-secondary mt-0.5">{l.description}</p>
          </div>
        ))}
      </div>
    </section>

    {lore.artefacts.length > 0 && (
      <section class="mb-14">
        <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-5">Artefacts</p>
        <div class="grid md:grid-cols-2 gap-3">
          {lore.artefacts.map(a => (
            <div class="bg-void-card border border-void-border rounded-xl p-4">
              <p class="text-sm font-semibold text-cyan">{a.nom}</p>
              <p class="text-sm text-text-secondary mt-0.5">{a.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {lore.technologies.length > 0 && (
      <section class="mb-14">
        <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-5">Technologies</p>
        {lore.technologies.map(t => (
          <div class="bg-void-card border border-void-border rounded-xl p-4">
            <div class="flex items-center justify-between mb-1">
              <p class="text-sm font-semibold text-text">{t.nom}</p>
              <span class="text-xs text-text-muted">{t.statut}</span>
            </div>
            <p class="text-sm text-text-secondary">{t.description}</p>
          </div>
        ))}
      </section>
    )}

    {lore.personnages.length > 0 && (
      <section class="mb-14">
        <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-5">Personnages</p>
        <div class="grid md:grid-cols-2 gap-3">
          {lore.personnages.map(p => (
            <div class="bg-void-card border border-void-border rounded-xl p-4">
              <p class="text-sm font-semibold text-text">{p.nom}</p>
              <p class="text-sm text-text-secondary mt-0.5">{p.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
