---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLore } from '../lib/lore';

const lore = await getLore();
---

<BaseLayout title="Lore & Timeline — Résonance" description="L'univers de Résonance : factions, lieux, événements, technologies">
  <div class="max-w-4xl mx-auto px-4 py-12 md:py-20">
    <header class="text-center mb-16">
      <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
        L'Univers de Résonance
      </h1>
      <p class="text-slate-400">
        Une encyclopédie vivante, enrichie à chaque chapitre
      </p>
    </header>

    <!-- Frise chronologique -->
    <section class="mb-16">
      <h2 class="font-display text-2xl font-semibold text-white mb-8">Chronologie</h2>
      <div class="relative">
        <div class="absolute left-4 top-0 bottom-0 w-px bg-ether-600/30"></div>
        <div class="space-y-8">
          {lore.evenementsCles.map((event) => (
            <div class="relative pl-12">
              <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-ether-500 ring-4 ring-void-950"></div>
              <h3 class="font-display font-semibold text-white text-lg">{event.nom}</h3>
              <p class="text-slate-400 text-sm mt-1">{event.description}</p>
              <span class="text-xs text-slate-600 mt-1 block">Source : {event.chapitre}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Factions -->
    <section class="mb-16">
      <h2 class="font-display text-2xl font-semibold text-white mb-8">Factions</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {lore.factions.map((faction) => (
          <div class="bg-void-800/30 border border-void-700 rounded-xl p-5">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-display font-semibold text-white">{faction.nom}</h3>
              <span class:list={[
                'text-xs px-2 py-0.5 rounded-full border',
                faction.statut === 'dissoute' && 'bg-danger-500/20 text-danger-400 border-danger-500/30',
                faction.statut === 'clandestins' && 'bg-fracture-500/20 text-fracture-300 border-fracture-500/30',
                faction.statut === 'disparus' && 'bg-void-700 text-slate-500 border-void-600',
                faction.statut === 'actives' && 'bg-awakened-500/20 text-awakened-300 border-awakened-500/30',
              ]}>
                {faction.statut}
              </span>
            </div>
            <p class="text-slate-400 text-sm">{faction.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Lieux -->
    <section class="mb-16">
      <h2 class="font-display text-2xl font-semibold text-white mb-8">Lieux connus</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {lore.lieux.map((lieu) => (
          <div class="bg-void-800/30 border border-void-700 rounded-xl p-5">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="font-display font-semibold text-white">{lieu.nom}</h3>
              <span class="text-xs text-slate-600">({lieu.type})</span>
            </div>
            <p class="text-slate-400 text-sm">{lieu.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Artefacts -->
    {lore.artefacts.length > 0 && (
      <section class="mb-16">
        <h2 class="font-display text-2xl font-semibold text-white mb-8">Artefacts des Bâtisseurs</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {lore.artefacts.map((artefact) => (
            <div class="bg-void-800/30 border border-void-700 rounded-xl p-5">
              <h3 class="font-display font-semibold text-ether-300 mb-1">{artefact.nom}</h3>
              <p class="text-slate-400 text-sm">{artefact.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Technologies -->
    {lore.technologies.length > 0 && (
      <section class="mb-16">
        <h2 class="font-display text-2xl font-semibold text-white mb-8">Technologies</h2>
        <div class="space-y-4">
          {lore.technologies.map((tech) => (
            <div class="bg-void-800/30 border border-void-700 rounded-xl p-5">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-display font-semibold text-white">{tech.nom}</h3>
                <span class="text-xs text-fracture-300">{tech.statut}</span>
              </div>
              <p class="text-slate-400 text-sm">{tech.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Personnages (vide pour l'instant) -->
    {lore.personnages.length > 0 && (
      <section class="mb-16">
        <h2 class="font-display text-2xl font-semibold text-white mb-8">Personnages</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {lore.personnages.map((perso) => (
            <div class="bg-void-800/30 border border-void-700 rounded-xl p-5">
              <h3 class="font-display font-semibold text-white mb-1">{perso.nom}</h3>
              <p class="text-slate-400 text-sm">{perso.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
